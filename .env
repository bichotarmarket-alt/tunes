ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
LOG_FILE=logs/autotrade.log
LOG_ROTATION=1 day
LOG_RETENTION=7 days
LOG_FORMAT="{time:YYYY-MM-DD HH:mm:ss} | {level} | {name}:{function}:{line} | {message}"
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
SECRET_KEY=dev-secret-key-change-for-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
DATABASE_URL=postgresql+asyncpg://postgres:root@localhost:5432/tunestrade
DB_ECHO=false
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false
REDIS_CACHE_TTL=300
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_ENABLED=false
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_MINUTE_AUTH=300
CORS_ORIGINS=
CORS_ALLOW_CREDENTIALS=true
SENTRY_DSN=
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@autotrade.com
SMTP_USE_TLS=true
EMAIL_ENABLED=false
TELEGRAM_BOT_TOKEN=8209575841:AAEp4EJAblEHF2NTqkUIJqA-oII5Y4hs3eI
TELEGRAM_ENABLED=true
POCKETOPTION_DEMO_SSID=
POCKETOPTION_LIVE_SSID=
POCKETOPTION_DEFAULT_REGION=EUROPA
POCKETOPTION_PING_INTERVAL=20
POCKETOPTION_RECONNECT_DELAY=5
POCKETOPTION_MAX_RECONNECT_ATTEMPTS=10
MAX_TRADES_PER_DAY=20
MAX_TRADES_SIMULTANEOUS=5
MAX_TRADE_AMOUNT=100.0
MAX_DAILY_LOSS_PERCENT=5.0
MIN_SIGNAL_CONFIDENCE=0.7
DATA_COLLECTION_INTERVAL=1
HISTORICAL_DATA_DAYS=365
MAX_CANDLES_PER_REQUEST=1000
DATA_COLLECTOR_ENABLED=true
DEFAULT_TIMEFRAME=60
DEFAULT_AMOUNT=10.0
DEFAULT_DURATION=60
STRATEGY_BACKTEST_INITIAL_BALANCE=1000.0
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=1000
WS_MESSAGE_QUEUE_SIZE=100
